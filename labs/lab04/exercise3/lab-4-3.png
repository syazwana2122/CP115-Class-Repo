<?xml version="1.0"?>
<flowgorithm fileversion="4.2">
    <attributes>
        <attribute name="name" value="lab-4-3"/>
        <attribute name="authors" value="User"/>
        <attribute name="about" value=""/>
        <attribute name="saved" value="2026-07-14 10:19:22 AM"/>
        <attribute name="created" value="VXNlcjtERVNLVE9QLUozOVAxTlQ7MjAyNi0wNy0xNDsxMDowMTo0MiBBTTsyNzMw"/>
        <attribute name="edited" value="VXNlcjtERVNLVE9QLUozOVAxTlQ7MjAyNi0wNy0xNDsxMDoxOToyMiBBTTsxOzI4NDU="/>
    </attributes>
    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="hours" type="Real" array="False" size=""/>
            <input variable="hours"/>
            <declare name="charges" type="Real" array="False" size=""/>
            <if expression="hours &lt;= 2">
                <then>
                    <assign variable="charges" expression="0"/>
                </then>
                <else>
                    <if expression="hours &lt;= 5">
                        <then>
                            <assign variable="charges" expression="(hours - 2) * 2"/>
                        </then>
                        <else>
                            <assign variable="charges" expression="(3 * 2) + (hours - 5)"/>
                        </else>
                    </if>
                </else>
            </if>
            <declare name="parkingFee" type="Real" array="False" size=""/>
            <assign variable="parkingFee" expression="charges * hours"/>
            <output expression="parkingFee" newline="True"/>
        </body>
    </function>
</flowgorithm>
